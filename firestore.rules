// firestore.rules
// ════════════════════════════════════════════════════════════════
//  Kerich Pharmaceuticals — Firestore Security Rules
//  Compliant with Kenya Data Protection Act 2019
//  PPB regulatory requirements
// ════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function role() {
      return request.auth.token.kerich_role;
    }

    function isAdmin() {
      return isAuthenticated() && role() == 'admin';
    }

    function isPharmacist() {
      return isAuthenticated() && (role() == 'pharmacist' || role() == 'admin');
    }

    function isDoctor() {
      return isAuthenticated() && (role() == 'doctor' || role() == 'admin');
    }

    function isRider() {
      return isAuthenticated() && (role() == 'rider' || role() == 'admin');
    }

    function isOwner(userId) {
      return isAuthenticated() && uid() == userId;
    }

    function isClinical() {
      return isAuthenticated() && role() in ['admin', 'pharmacist', 'doctor'];
    }

    // ── Users / Patient Profiles ─────────────────────────────
    match /users/{userId} {
      // Patients read own profile; clinical staff read any
      allow read: if isOwner(userId) || isClinical();

      // Only the user can create their own profile (set on register)
      allow create: if isOwner(userId)
        && request.resource.data.role == 'patient'  // cannot self-assign elevated role
        && request.resource.data.keys().hasAll(['email', 'displayName', 'role', 'createdAt']);

      // User updates own safe fields; admin updates anything
      allow update: if isOwner(userId) && onlySafeUserFields()
                  || isAdmin();

      // Hard-delete blocked — admin anonymises via server (Kenya DPA 2019)
      allow delete: if false;

      function onlySafeUserFields() {
        let allowed = ['displayName', 'phoneNumber', 'healthProfile', 'updatedAt'];
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
      }
    }

    // ── Products / Inventory ─────────────────────────────────
    match /products/{productId} {
      // Anyone (even unauthenticated) can browse active products
      allow read: if resource.data.active == true || isPharmacist();

      // Only pharmacist / admin can create or modify
      allow create, update: if isPharmacist();
      allow delete:         if isAdmin();
    }

    // ── Orders ───────────────────────────────────────────────
    match /orders/{orderId} {
      // Patient reads own orders; clinical / rider read any
      allow read: if isOwner(resource.data.patientId)
               || isClinical()
               || isRider();

      // Patient creates order for themselves only
      allow create: if isAuthenticated()
        && request.resource.data.patientId == uid()
        && request.resource.data.keys().hasAll(['patientId', 'items', 'total', 'status', 'createdAt']);

      // Status updates by clinical/admin/rider; patient cannot update
      allow update: if isClinical() || isRider();

      allow delete: if false;
    }

    // ── Prescriptions ────────────────────────────────────────
    match /prescriptions/{rxId} {
      // Patient reads own; clinical reads any
      allow read: if isOwner(resource.data.patientId) || isClinical();

      // Patient uploads new prescription
      allow create: if isAuthenticated()
        && request.resource.data.patientId == uid()
        && request.resource.data.status == 'pending_verification';

      // Only pharmacist / admin can verify or reject
      allow update: if isPharmacist()
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status','verifiedBy','verifiedAt','rejectionReason','expiryDate','updatedAt']);

      allow delete: if false;  // Rx records must be retained (PPB requirement)
    }

    // ── Deliveries / Tracking ─────────────────────────────────
    match /deliveries/{deliveryId} {
      allow read:   if isAuthenticated();
      allow create: if isPharmacist();
      allow update: if isRider() || isAdmin();
      allow delete: if false;
    }

    // ── Payments ─────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:   if isOwner(resource.data.patientId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.patientId == uid();
      // Only server-side (Admin SDK) updates payment status via backend
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Consultations ─────────────────────────────────────────
    match /consultations/{consultId} {
      allow read:   if isOwner(resource.data.patientId) || isClinical();
      allow create: if isAuthenticated();
      allow update: if isClinical();
      allow delete: if false;
    }

    // ── Audit Logs — write-only from clients, read by admin ──
    match /audit_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated();  // server writes; clients cannot
      allow update, delete: if false;     // immutable
    }

    // ── Error logs — server only ──────────────────────────────
    match /error_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
